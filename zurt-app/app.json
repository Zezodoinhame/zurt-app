{
  "expo": {
    "name": "ZURT",
    "slug": "zurt-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "zurt",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080D14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.zurt.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ZURT precisa acessar a câmera para foto de perfil",
        "NSPhotoLibraryUsageDescription": "ZURT precisa acessar suas fotos para foto de perfil",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080D14"
      },
      "edgeToEdgeEnabled": true,
      "package": "br.com.zurt.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "822526137511-j4i3icif8pdgg5om2s163489f88nhb58.apps.googleusercontent.com"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Permitir ZURT usar Face ID para autenticação segura."
        }
      ],
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir ZURT usar Face ID para login seguro."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ZURT precisa acessar suas fotos para foto de perfil",
          "cameraPermission": "ZURT precisa acessar a câmera para foto de perfil"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00D4AA"
        }
      ]
    ]
  }
}
