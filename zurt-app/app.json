{
  "expo": {
    "name": "ZURT Wealth",
    "slug": "zurt-wealth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "zurt",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#060A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zurt.wealth"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060A0F"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.zurt.wealth"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Permitir ZURT usar Face ID para autenticação segura."
        }
      ],
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir ZURT usar Face ID para login seguro."
        }
      ]
    ]
  }
}
